# Copy this file to .env and fill in your keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Diagnostics Engine
DIAG_POLL_INTERVAL=10        # seconds between diagnostic cycles
DIAG_ANOMALY_WINDOW=300      # rolling window size for Z-score (seconds)
DIAG_ZSCORE_THRESHOLD=3.0    # Z-score threshold for anomaly alerts

# Pipeline
PIPELINE_STT_BACKEND=mock    # mock | whisper | deepgram
PIPELINE_LLM_BACKEND=mock    # mock | claude | openai
