{
  "title": "Speech AI — Pipeline Overview",
  "uid": "speech-ai-overview",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "STT Word Error Rate",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "stt_word_error_rate",
          "legendFormat": "WER"
        }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.15 },
            { "color": "red", "value": 0.20 }
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Audio SNR (dB)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "audio_snr_db",
          "legendFormat": "SNR dB"
        }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 10 },
            { "color": "green", "value": 15 }
          ]
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "LLM P99 Latency (ms)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "llm_api_latency_p99_ms",
          "legendFormat": "P99 ms"
        }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 2000 },
            { "color": "red", "value": 3000 }
          ]
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "CPU %",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "system_cpu_percent",
          "legendFormat": "CPU %"
        }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 85 }
          ]
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "LLM 429 Error Rate",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "llm_error_rate_429",
          "legendFormat": "429 Rate"
        }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.05 },
            { "color": "red", "value": 0.10 }
          ]
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "STT Word Error Rate — Time Series",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "stt_word_error_rate",
          "legendFormat": "WER"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "LLM API Latency P99",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "llm_api_latency_p99_ms",
          "legendFormat": "P99 ms"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Audio SNR",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "audio_snr_db",
          "legendFormat": "SNR dB"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "System Resources",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "system_cpu_percent",
          "legendFormat": "CPU %"
        },
        {
          "datasource": "Prometheus",
          "expr": "system_memory_percent",
          "legendFormat": "Memory %"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Diagnostic Reports Generated",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 5 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(diagnostics_report_total[1m])",
          "legendFormat": "Reports / min"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Pipeline E2E Latency P99",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 5 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "pipeline_e2e_latency_p99_ms",
          "legendFormat": "E2E P99 ms"
        }
      ]
    }
  ]
}
